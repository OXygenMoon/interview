# 基础环境变量
VUE_APP_NAME=简历制作系统
VUE_APP_VERSION=1.0.0
VUE_APP_DESCRIPTION=为技校学生打造的专属简历工具

# API配置
VUE_APP_API_URL=http://localhost:3001/api
VUE_APP_TIMEOUT=10000

# 功能开关
VUE_APP_ENABLE_ANALYTICS=false
VUE_APP_ENABLE_PWA=false
VUE_APP_ENABLE_OFFLINE=false

# 开发配置
VUE_APP_DEBUG=true
VUE_APP_SHOW_DEV_TOOLS=true